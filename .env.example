# Ollama server
OLLAMA_HOST=http://localhost:11434

# Model served by Ollama (must be pulled first: ollama pull gpt-oss:20b)
MODEL_NAME=gpt-oss:20b

# Logging level: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO

# Maximum CoVe (Chain-of-Verification) rounds per step before surfacing to user
MAX_COVE_ROUNDS=2

# Session storage directory (relative or absolute)
SESSION_DIR=sessions

# PDF export — set to "false" to skip even if reportlab is installed
PDF_EXPORT_ENABLED=true
